#!/usr/bin/env python3
"""
hermes-skill-add — 给已有 Agent 注册新技能的 CLI 入口脚本

用法:
    hermes-skill-add --agent <agent> --category <category> --name <name> --layer <1-4> --load <auto|manual> [options]

必要参数:
    --agent <str>       Agent 名
    --category <str>    技能分类（如 "架构治理"）
    --name <str>        技能名（如 "multi-agent-arch"）
    --layer <1-4>       技能层级
    --load <auto|manual> 加载模式

可选参数:
    --intentional       是否需明确调用（标志）
    --ref <str>         参考文档路径
    --add-route         是否同时加路由规则（标志）
    --route-pattern <str>  路由匹配模式（配合 --add-route）
    --route-type <str>     路由规则类型（默认 phrase，可选 phrase/regex/keyword）
    --route-weight <float> 路由规则权重（默认 1.0）
"""

from __future__ import annotations

import argparse
import json
import os
import re
import subprocess
import sys
from pathlib import Path
from typing import Any, Dict, List, Optional, Tuple

# ── 导入 agent-mgmt 模块 ──────────────────────────────────────
_MGMT_DIR = Path(__file__).resolve().parent / "agent-mgmt"
if str(_MGMT_DIR) not in sys.path:
    sys.path.insert(0, str(_MGMT_DIR))

from _binding_table import add_binding_row, parse_binding_table
from _transaction import FileTransaction
from _validation import check_agent_exist, check_skill_global_unique
from _yaml_ops import _write_yaml, read_yaml

# ── 路径常量 ──────────────────────────────────────────────────
_PROJECT_ROOT = Path(__file__).resolve().parent.parent

SKILL_MAP = _PROJECT_ROOT / "skill-map.yaml"
SOUL_MD = _PROJECT_ROOT / "SOUL.md"
ROUTES_DIR = _PROJECT_ROOT / "route-map" / "routes"

REBUILD_CACHE = _PROJECT_ROOT / "scripts" / "rebuild-cache.py"
VALIDATE_SKILL_MAP = _PROJECT_ROOT / "scripts" / "validate-skill-map.py"
VALIDATE_ROUTE_MAP = _PROJECT_ROOT / "scripts" / "validate-route-map.py"

# ── 解析参数 ──────────────────────────────────────────────────


def parse_args(argv: Optional[List[str]] = None) -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="给已有 Agent 注册新技能",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=(
            "示例:\n"
            "  hermes-skill-add --agent pm-agent --category 新分类 --name my-skill "
            "--layer 3 --load manual\n"
            "  hermes-skill-add --agent programmer --category 方法论 --name my-skill "
            "--layer 2 --load auto --intentional --add-route --route-pattern \"关键词\"\n"
        ),
    )
    parser.add_argument("--agent", required=True, help="Agent 名")
    parser.add_argument("--category", required=True, help="技能分类")
    parser.add_argument("--name", required=True, help="技能名")
    parser.add_argument(
        "--layer",
        required=True,
        choices=["1", "2", "3", "4"],
        help="技能层级 (1-4)",
    )
    parser.add_argument(
        "--load",
        required=True,
        choices=["auto", "manual"],
        help="加载模式",
    )
    parser.add_argument(
        "--intentional",
        action="store_true",
        help="是否需明确调用（跨 Agent 冲突标注）",
    )
    parser.add_argument("--ref", help="参考文档路径（如 shared.分类.skill-name）")
    parser.add_argument(
        "--add-route",
        action="store_true",
        help="是否同时加路由规则",
    )
    parser.add_argument("--route-pattern", help="路由匹配模式（配合 --add-route）")
    parser.add_argument(
        "--route-type",
        default="phrase",
        choices=["phrase", "regex", "keyword"],
        help="路由规则类型（默认 phrase）",
    )
    parser.add_argument(
        "--route-weight",
        type=float,
        default=1.0,
        help="路由规则权重（默认 1.0）",
    )

    args = parser.parse_args(argv)

    # 校验 agent 名称格式
    if not re.match(r"^[a-z0-9_-]+$", args.agent):
        print(
            f"错误: agent 名称「{args.agent}」不合法 — "
            "仅允许小写字母、数字、连字符和下划线（^[a-z0-9_-]+$）",
            file=sys.stderr,
        )
        sys.exit(1)

    return args


# ── 校验 ──────────────────────────────────────────────────────


def validate_args(args: argparse.Namespace) -> None:
    """全部校验，失败时 sys.exit(1)。"""

    # 1) agent 必须存在
    ok, msg = check_agent_exist(args.agent)
    if not ok:
        print(f"错误: {msg}", file=sys.stderr)
        sys.exit(1)

    # 2) skill 名称必须全局唯一
    ok, msg = check_skill_global_unique(args.name)
    if not ok:
        print(f"错误: {msg}", file=sys.stderr)
        sys.exit(1)

    # 3) layer 值已在 argparse choices 中校验，但做二次确认
    layer_int = int(args.layer)
    if layer_int < 1 or layer_int > 4:
        print(f"错误: layer 必须为 1-4，收到: {args.layer}", file=sys.stderr)
        sys.exit(1)

    # 4) --add-route 和 --route-pattern 必须同时出现
    if args.add_route and not args.route_pattern:
        print(
            "错误: --add-route 必须配合 --route-pattern 使用",
            file=sys.stderr,
        )
        sys.exit(1)
    if args.route_pattern and not args.add_route:
        print(
            "错误: --route-pattern 必须配合 --add-route 使用",
            file=sys.stderr,
        )
        sys.exit(1)

    # 5) 若 --add-route，route 文件必须存在
    if args.add_route:
        route_path = ROUTES_DIR / f"{args.agent}.yaml"
        if not route_path.is_file():
            print(
                f"错误: route 文件不存在: {route_path}\n"
                f"请先为 agent「{args.agent}」创建路由规则文件",
                file=sys.stderr,
            )
            sys.exit(1)


# ── skill-map.yaml 追加 ─────────────────────────────────────


def add_skill_to_skill_map(
    agent: str,
    category: str,
    name: str,
    layer: str,
    load: str,
    intentional: bool,
    ref: Optional[str],
) -> None:
    """向 skill-map.yaml 中对应 agent/category 追加一条 skill 定义。"""
    data = read_yaml(str(SKILL_MAP))

    # 确保 agents → agent → categories 路径存在
    agents = data.setdefault("agents", {})
    agent_data = agents.setdefault(agent, {})
    categories = agent_data.setdefault("categories", {})

    if category not in categories:
        categories[category] = []

    # 构建 skill 条目
    skill_entry: Dict[str, Any] = {
        "name": name,
        "layer": f"{layer} / load: {load}",
    }
    if intentional:
        skill_entry["intentional"] = True
    if ref:
        skill_entry["ref"] = ref

    categories[category].append(skill_entry)
    _write_yaml(str(SKILL_MAP), data)
    print(f"  ✓ skill-map.yaml: 已追加 {agent} > {category} > {name}")


# ── route 文件追加 ──────────────────────────────────────────


def add_route_rule(
    agent: str,
    skill_name: str,
    pattern: str,
    route_type: str,
    weight: float,
) -> None:
    """向 route-map/routes/{agent}.yaml 追加一条路由规则。"""
    route_path = ROUTES_DIR / f"{agent}.yaml"

    data = read_yaml(str(route_path))
    rules = data.setdefault("rules", [])

    rule = {
        "type": route_type,
        "pattern": pattern,
        "weight": weight,
        "skills": [skill_name],
    }
    rules.append(rule)
    _write_yaml(str(route_path), data)
    print(
        f"  ✓ route-map/routes/{agent}.yaml: 已追加规则 "
        f"(type={route_type}, pattern={pattern})"
    )


# ── SOUL.md 绑定表更新 ──────────────────────────────────────


def _find_binding_table_bounds(
    lines: List[str],
) -> Tuple[int, int, int]:
    """定位 SOUL.md 中绑定表的三个关键行号。

    Returns:
        (section_header_idx, separator_idx, data_end_idx)
        未找到时返回 (-1, -1, -1)。
    """
    section_marker = "## Agent→Skill 绑定表"
    header_start = "| Agent |"
    header_idx = -1
    separator_idx = -1

    for i, line in enumerate(lines):
        stripped = line.strip()
        if section_marker in stripped:
            continue  # 找到章节标题，继续找表头
        if stripped.startswith(header_start):
            header_idx = i
            # 下一行应该是分隔行
            if i + 1 < len(lines):
                separator_idx = i + 1
            break

    if header_idx < 0 or separator_idx < 0:
        return (-1, -1, -1)

    # 数据行从 separator_idx + 1 开始，到空行或文件尾结束
    data_end = separator_idx + 1
    for j in range(data_end, len(lines)):
        stripped = lines[j].strip()
        if not stripped or not stripped.startswith("|"):
            data_end = j
            break
    else:
        data_end = len(lines)

    return (header_idx - 1, separator_idx, data_end)
    # 返回 section_header_idx（章节标题行）, separator_idx, data_end


def update_soul_binding_table(
    agent: str,
    skill_name: str,
    load: str,
) -> None:
    """更新 SOUL.md 绑定表，将新技能添加到对应 agent 行。

    Args:
        agent:      Agent 名称。
        skill_name: 技能名称。
        load:       加载模式 ("auto" → L2 列, "manual" → L3 列)。
    """
    if not SOUL_MD.is_file():
        print("  ⚠ SOUL.md 不存在，跳过绑定表更新", file=sys.stderr)
        return

    with open(SOUL_MD, "r", encoding="utf-8") as f:
        content = f.read()
    lines = content.split("\n")

    # 解析当前绑定表
    binding_dict = parse_binding_table(content)
    if not binding_dict:
        print("  ⚠ 无法解析 SOUL.md 绑定表，跳过更新", file=sys.stderr)
        return

    # 更新或创建该 agent 的条目
    if agent not in binding_dict:
        binding_dict[agent] = {"l2": [], "l3": [], "condition": ""}

    entry = binding_dict[agent]
    if load == "auto":
        if skill_name not in entry["l2"]:
            entry["l2"].append(skill_name)
    else:  # manual
        if skill_name not in entry["l3"]:
            entry["l3"].append(skill_name)

    # 定位表格边界
    section_header_idx, separator_idx, data_end = _find_binding_table_bounds(lines)

    if section_header_idx < 0:
        print("  ⚠ 未找到绑定表章节，跳过更新", file=sys.stderr)
        return

    # 保留：章节标题之前的全部内容 + 表头 + 分隔行
    prefix_lines = lines[:separator_idx + 1]

    # 保留：数据行之后的内容（footer）
    footer_lines = lines[data_end:]

    # 按 agent 名称顺序重建数据行（保持一致的排序）
    sorted_agents = sorted(binding_dict.keys())
    data_rows: List[str] = []
    for ag in sorted_agents:
        entry = binding_dict[ag]
        row = add_binding_row(
            agent_name=ag,
            l2_skills=entry["l2"],
            l3_skills=entry["l3"],
            condition=entry.get("condition", ""),
        )
        data_rows.append(row.rstrip("\n"))

    # 重新组装
    new_lines = prefix_lines + data_rows + footer_lines
    new_content = "\n".join(new_lines)

    with open(SOUL_MD, "w", encoding="utf-8") as f:
        f.write(new_content)

    col = "L2 auto" if load == "auto" else "L3 manual"
    print(f"  ✓ SOUL.md: 已更新 {agent} 的 {col} 列（+{skill_name}）")


# ── 调用校验脚本 ────────────────────────────────────────────


def run_script(script_path: Path, label: str) -> bool:
    """运行一个 Python 校验脚本，返回 True=通过。

    Args:
        script_path: 脚本路径。
        label:       脚本名称（用于日志）。

    Returns:
        True 表示无 ERR（退出码 0 或 1 均可），False 表示有 ERR（退出码 2）。
    """
    if not script_path.is_file():
        print(f"  ⚠ {label} 脚本不存在: {script_path}", file=sys.stderr)
        return True  # 跳过

    try:
        result = subprocess.run(
            [sys.executable, str(script_path)],
            capture_output=True,
            text=True,
            timeout=60,
        )
    except subprocess.TimeoutExpired:
        print(f"  ✗ {label} 超时", file=sys.stderr)
        return False
    except Exception as e:
        print(f"  ✗ {label} 执行异常: {e}", file=sys.stderr)
        return False

    # 尝试解析 JSON 输出
    try:
        report = json.loads(result.stdout) if result.stdout.strip() else {}
    except json.JSONDecodeError:
        report = {}

    # validate-skill-map.py 退出码: 2=ERR, 1=WARN, 0=OK
    # validate-route-map.py 退出码: 2=ERR, 1=WARN, 0=OK
    status = report.get("status", "")
    err_count = report.get("errors", 0)

    if result.returncode == 2 or status == "FAIL" or status == "ERR":
        print(f"  ✗ {label}: 检测到错误")
        # 打印错误详情
        err_list = report.get("errors_list") or report.get("errors") or []
        for e in err_list:
            if isinstance(e, dict):
                msg = e.get("message", str(e))
            else:
                msg = str(e)
            print(f"      {msg}", file=sys.stderr)
        # 也打印 stderr
        if result.stderr.strip():
            print(f"      stderr: {result.stderr.strip()}", file=sys.stderr)
        return False

    if result.returncode == 1 or status == "WARN":
        print(f"  ⚠ {label}: 通过（含警告）")
    else:
        print(f"  ✓ {label}: 通过")

    # 输出 info 级别的信息
    info_list = report.get("info_list") or report.get("info") or []
    for i in info_list:
        if isinstance(i, dict):
            msg = i.get("message", str(i))
        else:
            msg = str(i)
        if msg:
            print(f"      {msg}")

    return True


# ── 主流程 ──────────────────────────────────────────────────


def main(argv: Optional[List[str]] = None) -> int:
    args = parse_args(argv)

    print(f"▸ 注册技能: {args.agent} > {args.category} > {args.name}")
    print(f"  layer={args.layer}, load={args.load}")

    # ── 步骤 0: 前置校验 ──
    validate_args(args)

    # ── 步骤 1: 事务保护 ──
    tx = FileTransaction()
    try:
        # 备份所有即将修改的文件
        tx.backup(str(SKILL_MAP))
        if args.add_route:
            tx.backup(str(ROUTES_DIR / f"{args.agent}.yaml"))
        if SOUL_MD.is_file():
            tx.backup(str(SOUL_MD))

        # ── 步骤 2: 追加入 skill-map.yaml ──
        add_skill_to_skill_map(
            agent=args.agent,
            category=args.category,
            name=args.name,
            layer=args.layer,
            load=args.load,
            intentional=args.intentional,
            ref=args.ref,
        )

        # ── 步骤 3: 追加路由规则（可选） ──
        if args.add_route:
            add_route_rule(
                agent=args.agent,
                skill_name=args.name,
                pattern=args.route_pattern,
                route_type=args.route_type,
                weight=args.route_weight,
            )

        # ── 步骤 4: 更新 SOUL.md 绑定表 ──
        update_soul_binding_table(
            agent=args.agent,
            skill_name=args.name,
            load=args.load,
        )

        # ── 步骤 5: 调用 rebuild-cache.py ──
        print("▸ 重建缓存…")
        ok = run_script(REBUILD_CACHE, "rebuild-cache.py")
        if not ok:
            print("错误: rebuild-cache.py 执行失败，正在回滚…", file=sys.stderr)
            tx.rollback()
            return 1

        # ── 步骤 6: 调用 validate-route-map.py + validate-skill-map.py ──
        print("▸ 验证 route-map…")
        route_ok = run_script(VALIDATE_ROUTE_MAP, "validate-route-map.py")

        print("▸ 验证 skill-map…")
        skill_ok = run_script(VALIDATE_SKILL_MAP, "validate-skill-map.py")

        if not route_ok or not skill_ok:
            print(
                "错误: 验证未通过，正在回滚所有修改…",
                file=sys.stderr,
            )
            tx.rollback()
            return 1

        # ── 步骤 7: 全部通过 → 提交 ──
        tx.commit()
        print("▸ 事务已提交 ✓")

        # ── 步骤 8: 提示编写 SKILL.md ──
        print()
        print(f"技能「{args.name}」注册成功！")
        print(f"请编写 skills/{args.category}/{args.name}/SKILL.md 完成技能文档")

        return 0

    except Exception as e:
        print(f"错误: {e}", file=sys.stderr)
        try:
            tx.rollback()
            print("已回滚所有修改", file=sys.stderr)
        except Exception as rb_e:
            print(f"回滚异常: {rb_e}", file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
